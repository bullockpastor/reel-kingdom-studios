STUDIO_ROOT=/Volumes/T9/ReelKingdomStudios
PORT=8010
VIDEO_DB_URL=postgres://localhost:5434/video_studio
REDIS_URL=redis://localhost:6381
STORYBOARD_LLM_PROVIDER=ollama
